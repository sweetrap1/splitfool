rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Groups ───────────────────────────────────────────────────────────────
    match /groups/{groupId} {

      // READ: Any authenticated user may read to validate a join code before
      // joining. Room codes are cryptographically random (UUID-based) so
      // brute-force enumeration is not a practical attack vector.
      // Authenticated-only prevents anonymous scraping.
      allow read: if request.auth != null;

      // CREATE: Caller must declare themselves as creator.
      allow create: if request.auth != null
                    && request.resource.data.creatorId == request.auth.uid;

      // UPDATE is allowed when ALL of the following hold:
      //   1. Caller is authenticated.
      //   2. Caller is either an existing member OR is joining for the first time.
      //   3. creatorId is NEVER allowed to change (prevents privilege escalation).
      //   4. memberIds can only grow OR the caller is the original creator
      //      (creator can remove/kick members; non-creators cannot evict each other).
      allow update: if request.auth != null
                    && (isExistingMember() || isJoiningNewMember())
                    && isCreatorIdImmutable()
                    && isMemberIdsValid();

      // DELETE: Only the original creator.
      allow delete: if request.auth != null
                    && resource.data.creatorId == request.auth.uid;

      // ── Helper functions ────────────────────────────────────────────────────

      // Caller is already a member of this group.
      function isExistingMember() {
        return request.auth.uid in resource.data.memberIds;
      }

      // New user joining: they add exactly their own UID to memberIds,
      // no existing member UIDs are removed.
      function isJoiningNewMember() {
        let incomingMemberIds = request.resource.data.memberIds;
        let existingMemberIds = resource.data.memberIds;
        return incomingMemberIds.hasAll(existingMemberIds)
               && request.auth.uid in incomingMemberIds
               && incomingMemberIds.size() == existingMemberIds.size() + 1;
      }

      // creatorId must match what's already stored — no one can self-promote.
      function isCreatorIdImmutable() {
        return request.resource.data.creatorId == resource.data.creatorId;
      }

      // memberIds rules:
      //   - The original creator may change memberIds freely (add/remove/kick).
      //   - All other members may only grow memberIds (join) or remove
      //     themselves (leave). They cannot evict other members.
      function isMemberIdsValid() {
        let incoming = request.resource.data.memberIds;
        let existing = resource.data.memberIds;
        let isCreator = request.auth.uid == resource.data.creatorId;
        // Creator has full control.
        // Non-creators: incoming must contain everything except possibly themselves.
        return isCreator
          || incoming.hasAll(existing.removeAll([request.auth.uid]));
      }
    }

    // ─── Deny everything else by default ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
