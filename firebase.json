{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "./",
    "ignore": [
      "firebase.json",
      "**/node_modules/**",
      "**/.*",
      "android.keystore",
      "app/**",
      "build/**",
      "functions/**",
      "firestore.rules",
      "firestore.indexes.json",
      "*.md",
      "package*.json"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions",
    "ignore": [
      "node_modules/**",
      ".git/**",
      "firebase-debug.log",
      "firebase-debug.*.log"
    ]
  }
}
